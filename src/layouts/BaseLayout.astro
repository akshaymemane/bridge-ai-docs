---
const {
  title = 'BridgeAIChat',
  description = 'Run one chat interface for AI CLIs across your own machines.'
} = Astro.props

const pathname = Astro.url.pathname
const nav = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/downloads', label: 'Downloads' },
  { href: '/roadmap', label: 'Roadmap' }
]
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #f5efe6;
        --bg-strong: #efe4d5;
        --paper: rgba(255, 252, 247, 0.86);
        --paper-strong: rgba(255, 250, 242, 0.95);
        --ink: #162319;
        --muted: #5e6d63;
        --line: rgba(22, 35, 25, 0.1);
        --accent: #ef6c2f;
        --accent-strong: #c74c16;
        --accent-soft: rgba(239, 108, 47, 0.12);
        --teal: #146c6e;
        --teal-soft: rgba(20, 108, 110, 0.12);
        --shadow: 0 24px 60px rgba(57, 39, 19, 0.1);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --radius-sm: 12px;
      }

      * { box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(20, 108, 110, 0.16), transparent 28%),
          radial-gradient(circle at top right, rgba(239, 108, 47, 0.14), transparent 24%),
          linear-gradient(180deg, #fbf6ef 0%, #f5efe6 45%, #efe7db 100%);
        font-family: "Avenir Next", "Helvetica Neue", "Segoe UI", sans-serif;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(22, 35, 25, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(22, 35, 25, 0.025) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.38), transparent 75%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        width: min(1160px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px);
        background: rgba(245, 239, 230, 0.78);
        border-bottom: 1px solid rgba(22, 35, 25, 0.08);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 18px 0;
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand-mark {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        background:
          linear-gradient(135deg, rgba(20, 108, 110, 0.95), rgba(239, 108, 47, 0.95));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
        display: grid;
        place-items: center;
        color: white;
        font-weight: 800;
        letter-spacing: -0.08em;
      }

      .brand-copy {
        display: grid;
        gap: 4px;
      }

      .brand {
        font-size: 1.05rem;
        font-weight: 800;
        letter-spacing: -0.05em;
      }

      .tagline {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .beta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent-strong);
        border: 1px solid rgba(239, 108, 47, 0.18);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
      }

      .nav-link {
        padding: 10px 14px;
        border-radius: 999px;
        color: var(--muted);
        transition: 180ms ease;
      }

      .nav-link:hover,
      .nav-link.active {
        color: var(--ink);
        background: rgba(255, 255, 255, 0.58);
      }

      main {
        padding: 42px 0 96px;
      }

      .hero,
      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.82fr);
        gap: 28px;
        align-items: stretch;
      }

      .card,
      .surface {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, var(--paper-strong), var(--paper));
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        padding: 30px;
        box-shadow: var(--shadow);
      }

      .card::after,
      .surface::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.25), transparent 26%);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--teal);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--teal), var(--accent));
      }

      h1,
      h2,
      h3 {
        margin: 0;
        letter-spacing: -0.055em;
        line-height: 0.98;
      }

      h1 {
        margin-top: 16px;
        font-size: clamp(2.8rem, 5vw, 4.8rem);
      }

      h2 {
        font-size: clamp(1.6rem, 2.4vw, 2.25rem);
        margin-bottom: 14px;
      }

      h3 {
        font-size: 1.2rem;
        margin-bottom: 10px;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
        font-size: 1rem;
      }

      .lede {
        margin-top: 18px;
        font-size: 1.08rem;
      }

      .section {
        margin-top: 34px;
      }

      .section-gap {
        margin-top: 62px;
      }

      .grid {
        display: grid;
        gap: 20px;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .grid.three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .stack {
        display: grid;
        gap: 18px;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 28px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-weight: 700;
        transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button.primary {
        background: linear-gradient(135deg, var(--accent), #ff9150);
        border-color: transparent;
        color: white;
      }

      .button.secondary {
        background: rgba(255, 255, 255, 0.65);
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid var(--line);
        color: var(--ink);
        font-size: 0.9rem;
      }

      .terminal {
        background: #13231f;
        color: #eff8ef;
        border-radius: 24px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .terminal-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
      }

      .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.28);
      }

      .terminal-dot:nth-child(1) { background: #ff7a59; }
      .terminal-dot:nth-child(2) { background: #ffca58; }
      .terminal-dot:nth-child(3) { background: #46c47c; }

      code,
      pre {
        font-family: "SFMono-Regular", "SF Mono", Menlo, Monaco, Consolas, monospace;
      }

      pre {
        margin: 0;
        padding: 18px;
        border-radius: var(--radius-md);
        border: 1px solid rgba(22, 35, 25, 0.08);
        background: rgba(17, 31, 27, 0.96);
        color: #f7fbf7;
        overflow: auto;
        line-height: 1.55;
      }

      .code-light {
        background: rgba(255, 255, 255, 0.72);
        color: #183223;
      }

      .note,
      .status {
        padding: 16px 18px;
        border-radius: var(--radius-md);
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.62);
        color: var(--muted);
      }

      .note strong,
      .status strong {
        color: var(--ink);
      }

      .status {
        background: var(--teal-soft);
        border-color: rgba(20, 108, 110, 0.18);
      }

      .list,
      ul {
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        line-height: 1.75;
      }

      .list.tight li + li {
        margin-top: 6px;
      }

      .step-list {
        display: grid;
        gap: 16px;
      }

      .step {
        padding: 18px 20px;
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid var(--line);
      }

      .step-number {
        display: inline-grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        margin-bottom: 12px;
        background: linear-gradient(135deg, var(--accent), var(--teal));
        color: white;
        font-weight: 800;
      }

      .mini-title {
        margin: 0 0 8px;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 26px;
      }

      .metric {
        padding: 18px;
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid var(--line);
      }

      .metric strong {
        display: block;
        margin-bottom: 6px;
        font-size: 1.4rem;
        letter-spacing: -0.06em;
      }

      .doc-links {
        display: grid;
        gap: 14px;
      }

      .doc-link {
        display: block;
        padding: 18px 20px;
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid var(--line);
      }

      .doc-link strong {
        display: block;
        margin-bottom: 6px;
        letter-spacing: -0.03em;
      }

      .table-wrap {
        overflow: auto;
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.62);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        text-align: left;
        padding: 16px;
        border-bottom: 1px solid rgba(22, 35, 25, 0.08);
        color: var(--muted);
      }

      th {
        color: var(--ink);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      tr:last-child td {
        border-bottom: none;
      }

      footer {
        border-top: 1px solid rgba(22, 35, 25, 0.08);
        padding: 28px 0 46px;
        color: var(--muted);
      }

      .footer-copy {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
      }

      .muted {
        color: var(--muted);
      }

      @media (max-width: 980px) {
        .hero,
        .hero-grid,
        .grid.two,
        .grid.three,
        .metric-grid {
          grid-template-columns: 1fr;
        }

        .nav {
          align-items: flex-start;
          flex-direction: column;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 24px, 1160px);
        }

        main {
          padding-top: 28px;
        }

        .card,
        .surface {
          padding: 22px;
          border-radius: 22px;
        }

        h1 {
          font-size: 2.55rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="shell nav">
        <div class="brand-wrap">
          <div class="brand-mark">B</div>
          <div class="brand-copy">
            <div class="brand">BridgeAIChat</div>
            <div class="tagline">Control plane for your own AI CLI fleet</div>
          </div>
          <div class="beta">Public Beta</div>
        </div>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((item) => (
            <a class={`nav-link${pathname === item.href || pathname.startsWith(item.href + '/') ? ' active' : ''}`} href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer>
      <div class="shell footer-copy">
        <div>BridgeAIChat beta docs. Releases ship through GitHub for the app and agent.</div>
        <div><a href="/downloads">Install</a> · <a href="/docs/quickstart">Quickstart</a> · <a href="/roadmap">Roadmap</a></div>
      </div>
    </footer>
  </body>
</html>
