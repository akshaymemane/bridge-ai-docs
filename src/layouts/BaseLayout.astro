---
const { title = 'BridgeAIChat', description = 'Chat with AI CLIs across your own devices.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #0a1220;
        --panel: #0f1b31;
        --panel-2: #13233d;
        --text: #e8eefc;
        --muted: #9cb1d1;
        --accent: #4fd1c5;
        --accent-2: #8be9d8;
        --border: rgba(156, 177, 209, 0.18);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(79, 209, 197, 0.12), transparent 36%),
          linear-gradient(180deg, #09111d 0%, #0b1526 100%);
        color: var(--text);
      }
      a { color: inherit; text-decoration: none; }
      .shell { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
      header {
        position: sticky;
        top: 0;
        backdrop-filter: blur(10px);
        background: rgba(9, 17, 29, 0.72);
        border-bottom: 1px solid var(--border);
        z-index: 10;
      }
      .nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 0;
      }
      .brand { font-weight: 800; letter-spacing: -0.04em; }
      .nav-links { display: flex; gap: 18px; color: var(--muted); font-size: 14px; }
      .beta {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 10px; border-radius: 999px;
        background: rgba(79, 209, 197, 0.14); color: var(--accent-2); font-size: 12px; font-weight: 700;
      }
      main { padding: 48px 0 80px; }
      .hero { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 32px; align-items: center; }
      .card {
        background: linear-gradient(180deg, rgba(19, 35, 61, 0.94), rgba(15, 27, 49, 0.94));
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
      }
      .eyebrow { color: var(--accent-2); text-transform: uppercase; letter-spacing: 0.16em; font-size: 12px; font-weight: 700; }
      h1, h2, h3 { letter-spacing: -0.04em; margin: 0; }
      h1 { font-size: 54px; line-height: 1.02; margin-top: 12px; }
      h2 { font-size: 28px; margin-bottom: 12px; }
      p { color: var(--muted); line-height: 1.65; }
      .cta-row { display: flex; gap: 14px; margin-top: 24px; flex-wrap: wrap; }
      .button {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 12px 18px; border-radius: 14px; font-weight: 700;
        border: 1px solid var(--border);
      }
      .button.primary { background: var(--accent); color: #042330; border-color: transparent; }
      .grid { display: grid; gap: 20px; }
      .grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .section { margin-top: 56px; }
      ul { color: var(--muted); padding-left: 18px; }
      code, pre {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, "Courier New", monospace;
      }
      pre {
        background: rgba(5, 10, 18, 0.75);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 16px;
        overflow: auto;
        color: #d6e4ff;
      }
      table { width: 100%; border-collapse: collapse; color: var(--muted); }
      th, td { border-bottom: 1px solid var(--border); padding: 12px 10px; text-align: left; }
      footer { border-top: 1px solid var(--border); color: var(--muted); padding: 26px 0 48px; }
      @media (max-width: 900px) {
        .hero, .grid.two, .grid.three { grid-template-columns: 1fr; }
        h1 { font-size: 42px; }
        .nav { flex-direction: column; align-items: flex-start; gap: 14px; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="shell nav">
        <div>
          <div class="brand">BridgeAIChat</div>
          <div class="beta">Public Beta</div>
        </div>
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/docs">Docs</a>
          <a href="/downloads">Downloads</a>
          <a href="/roadmap">Roadmap</a>
        </nav>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer>
      <div class="shell">BridgeAIChat beta docs. Downloads are published via GitHub Releases.</div>
    </footer>
  </body>
</html>
