---
const {
  title = 'BridgeAIChat Docs',
  description = 'Install, configure, and operate the BridgeAIChat beta.',
  section = ''
} = Astro.props

const pathname = Astro.url.pathname

const topNav = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/downloads', label: 'Downloads' },
  { href: '/roadmap', label: 'Roadmap' }
]

const sidebar = [
  {
    group: 'Getting Started',
    links: [
      { href: '/docs', label: 'Overview' },
      { href: '/docs/quickstart', label: 'Quickstart' },
    ]
  },
  {
    group: 'Installation',
    links: [
      { href: '/docs/install/control-host', label: 'Control host' },
      { href: '/docs/install/agent', label: 'Agent device' },
    ]
  },
  {
    group: 'Tools',
    links: [
      { href: '/docs/tools/codex', label: 'Codex' },
      { href: '/docs/tools/claude', label: 'Claude' },
    ]
  },
  {
    group: 'Networking',
    links: [
      { href: '/docs/networking/tailscale', label: 'Tailscale' },
    ]
  },
  {
    group: 'Reference',
    links: [
      { href: '/docs/troubleshooting', label: 'Troubleshooting' },
    ]
  }
]

function isActive(href: string) {
  if (href === '/docs') return pathname === '/docs' || pathname === '/docs/'
  return pathname === href || pathname.startsWith(href + '/')
}

// Build breadcrumb
const segments = pathname.replace(/\/$/, '').split('/').filter(Boolean)
const crumbs: { label: string; href: string }[] = []
if (segments.length > 1) {
  crumbs.push({ label: 'Docs', href: '/docs' })
  if (segments.length > 2) {
    const groupLabel: Record<string, string> = {
      install: 'Installation',
      tools: 'Tools',
      networking: 'Networking'
    }
    if (groupLabel[segments[1]]) {
      crumbs.push({ label: groupLabel[segments[1]], href: '#' })
    }
  }
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #fafaf9;
        --surface: #ffffff;
        --border: #e7e5e4;
        --border-strong: #d6d3d1;
        --ink: #1c1917;
        --ink-2: #44403c;
        --muted: #78716c;
        --accent: #ea6c2f;
        --accent-hover: #c4521f;
        --accent-soft: rgba(234, 108, 47, 0.08);
        --accent-soft-border: rgba(234, 108, 47, 0.22);
        --teal: #0f766e;
        --teal-soft: rgba(15, 118, 110, 0.08);
        --teal-soft-border: rgba(15, 118, 110, 0.22);
        --header-bg: #0c0a09;
        --header-border: rgba(255,255,255,0.08);
        --sidebar-width: 256px;
        --radius-xl: 16px;
        --radius-lg: 12px;
        --radius-md: 8px;
        --radius-sm: 6px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 16px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }

      /* ── Header ── */
      header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--header-bg);
        border-bottom: 1px solid var(--header-border);
        height: 60px;
        display: flex;
        align-items: center;
      }

      .header-inner {
        width: 100%;
        max-width: none;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand-wrap { display: flex; align-items: center; gap: 10px; text-decoration: none; }

      .brand-mark {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        background: linear-gradient(135deg, var(--teal) 0%, var(--accent) 100%);
        display: grid;
        place-items: center;
        color: white;
        font-weight: 800;
        font-size: 0.82rem;
        letter-spacing: -0.05em;
        flex-shrink: 0;
      }

      .brand { font-size: 0.93rem; font-weight: 700; color: #ffffff; letter-spacing: -0.03em; }

      .beta-badge {
        padding: 2px 7px;
        border-radius: 999px;
        background: rgba(234, 108, 47, 0.18);
        color: #fb923c;
        border: 1px solid rgba(234, 108, 47, 0.28);
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .nav-links { display: flex; align-items: center; gap: 4px; }

      .nav-link {
        padding: 6px 12px;
        border-radius: 6px;
        color: rgba(255,255,255,0.55);
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 150ms, background 150ms;
      }
      .nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
      .nav-link.active { color: #fff; }

      /* ── Docs layout ── */
      .docs-wrapper {
        display: flex;
        min-height: calc(100vh - 60px - 73px);
        max-width: 1400px;
        margin: 0 auto;
      }

      /* ── Sidebar ── */
      .sidebar {
        width: var(--sidebar-width);
        flex-shrink: 0;
        border-right: 1px solid var(--border);
        padding: 28px 0;
        position: sticky;
        top: 60px;
        height: calc(100vh - 60px);
        overflow-y: auto;
        background: var(--surface);
      }

      .sidebar-inner { padding: 0 16px; }

      .sidebar-group { margin-bottom: 24px; }

      .sidebar-group-label {
        display: block;
        padding: 0 12px 8px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .sidebar-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 7px;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--ink-2);
        transition: color 150ms, background 150ms;
        margin-bottom: 2px;
      }

      .sidebar-link:hover { color: var(--ink); background: var(--bg); }

      .sidebar-link.active {
        color: var(--accent);
        background: var(--accent-soft);
        font-weight: 600;
      }

      .sidebar-link.active::before {
        content: '';
        width: 3px;
        height: 14px;
        border-radius: 999px;
        background: var(--accent);
        flex-shrink: 0;
      }

      /* ── Content ── */
      .content-area {
        flex: 1;
        min-width: 0;
        padding: 36px 48px 80px;
        max-width: 860px;
      }

      /* ── Breadcrumb ── */
      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 28px;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .breadcrumb a { color: var(--muted); transition: color 150ms; }
      .breadcrumb a:hover { color: var(--ink); }
      .breadcrumb-sep { color: var(--border-strong); }
      .breadcrumb-current { color: var(--ink-2); font-weight: 500; }

      /* ── Typography ── */
      h1, h2, h3, h4 { margin: 0; font-weight: 800; letter-spacing: -0.035em; line-height: 1.2; }

      h1 { font-size: clamp(1.75rem, 3vw, 2.4rem); color: var(--ink); }
      h2 { font-size: clamp(1.15rem, 1.8vw, 1.35rem); color: var(--ink); margin-bottom: 10px; }
      h3 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 8px; letter-spacing: -0.02em; }

      p { margin: 0; color: var(--ink-2); line-height: 1.75; }
      p + p { margin-top: 0.875em; }

      /* heading → content spacing */
      h1 + p, h1 + .lede { margin-top: 14px; }
      h2 + p, h2 + ul, h2 + pre { margin-top: 10px; }
      h3 + p, h3 + ul, h3 + pre { margin-top: 8px; }
      .eyebrow + h1, .eyebrow + h2 { margin-top: 8px; }

      /* element → pre spacing */
      p + pre, ul + pre { margin-top: 14px; }
      pre + p, pre + ul { margin-top: 14px; }
      pre + .note, pre + .status { margin-top: 12px; }
      .note + .note { margin-top: 8px; }

      .lede { font-size: 1.0625rem; line-height: 1.75; color: var(--ink-2); }

      /* ── Surface / Cards ── */
      .surface {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 32px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 32px;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 24px;
        box-shadow: var(--shadow-sm);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--teal);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .eyebrow::before {
        content: "";
        width: 5px;
        height: 5px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--teal), var(--accent));
      }

      /* ── Sections ── */
      .section { margin-top: 24px; }
      .section-gap { margin-top: 52px; }

      .grid { display: grid; gap: 14px; }
      .grid.two { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .grid.three { grid-template-columns: repeat(3, minmax(0,1fr)); }
      .stack { display: grid; gap: 12px; }

      /* ── Steps ── */
      .step-list { display: grid; gap: 12px; }

      .step {
        padding: 24px;
        border-radius: var(--radius-xl);
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
      }

      .step-number {
        display: inline-grid;
        place-items: center;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        margin-bottom: 14px;
        background: linear-gradient(135deg, var(--accent), #ff9150);
        color: white;
        font-weight: 800;
        font-size: 0.82rem;
      }

      .mini-title {
        margin: 0 0 12px;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
      }

      /* ── Code ── */
      code, pre { font-family: 'JetBrains Mono', 'SFMono-Regular', Menlo, monospace; }

      pre {
        margin: 14px 0 0;
        padding: 16px 18px;
        border-radius: var(--radius-lg);
        background: #0c0a09;
        color: #e7e5e4;
        overflow-x: auto;
        line-height: 1.65;
        font-size: 0.82rem;
        border: 1px solid rgba(255,255,255,0.06);
      }

      code {
        font-size: 0.82em;
        padding: 2px 7px;
        border-radius: 4px;
        background: rgba(234,108,47,0.07);
        color: #9a3412;
        border: 1px solid rgba(234,108,47,0.16);
        font-weight: 500;
      }

      pre code { background: none; border: none; padding: 0; font-size: inherit; color: inherit; }

      /* ── Notes / Status ── */
      .note {
        padding: 12px 16px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        border-left: 3px solid var(--border-strong);
        background: var(--bg);
        color: var(--ink-2);
        font-size: 0.9rem;
        line-height: 1.65;
      }
      .note strong { color: var(--ink); }

      .status {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 16px;
        border-radius: var(--radius-md);
        border: 1px solid var(--teal-soft-border);
        border-left: 3px solid var(--teal);
        background: var(--teal-soft);
        color: var(--teal);
        font-size: 0.9rem;
        line-height: 1.65;
      }
      .status strong { color: var(--teal); font-weight: 700; }

      /* ── Lists ── */
      .list, ul {
        margin: 0;
        padding-left: 0;
        list-style: none;
        color: var(--ink-2);
        line-height: 1.8;
      }

      .list li, ul li {
        position: relative;
        padding-left: 18px;
      }

      .list li::before, ul li::before {
        content: "–";
        position: absolute;
        left: 0;
        color: var(--accent);
        font-weight: 600;
      }

      .list.tight li + li, ul li + li { margin-top: 6px; }

      /* ── Doc links ── */
      .doc-links { display: grid; gap: 8px; }

      .doc-link {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border-radius: var(--radius-lg);
        background: var(--bg);
        border: 1px solid var(--border);
        transition: border-color 150ms, transform 150ms, box-shadow 150ms;
        font-size: 0.875rem;
      }

      .doc-link:hover {
        border-color: var(--accent-soft-border);
        transform: translateX(3px);
        box-shadow: var(--shadow-sm);
      }

      .doc-link strong { display: block; margin-bottom: 2px; color: var(--ink); font-weight: 600; font-size: 0.9rem; }
      .doc-link span, .doc-link p { color: var(--muted); font-size: 0.82rem; margin: 0; }

      .doc-link-arrow {
        color: var(--border-strong);
        font-size: 1.1rem;
        line-height: 1;
        flex-shrink: 0;
        margin-top: 2px;
        transition: color 150ms, transform 150ms;
      }
      .doc-link:hover .doc-link-arrow { color: var(--accent); transform: translateX(2px); }

      /* ── Table ── */
      .table-wrap {
        overflow: auto;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
      }

      table { width: 100%; border-collapse: collapse; }

      th, td {
        text-align: left;
        padding: 11px 14px;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
        color: var(--ink-2);
      }

      th {
        color: var(--ink);
        font-size: 0.72rem;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        font-weight: 600;
        background: var(--bg);
      }

      tr:last-child td { border-bottom: none; }

      /* ── Metric grid ── */
      .metric-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 10px; margin-top: 20px; }

      .metric {
        padding: 14px 16px;
        border-radius: var(--radius-lg);
        background: var(--bg);
        border: 1px solid var(--border);
      }

      .metric strong { display: block; margin-bottom: 3px; font-size: 1.2rem; letter-spacing: -0.05em; color: var(--ink); }
      .metric span { font-size: 0.78rem; color: var(--muted); }

      /* ── CTA / Buttons ── */
      .cta-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }

      .button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 40px;
        padding: 0 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 150ms;
        border: 1px solid transparent;
        cursor: pointer;
      }

      .button.primary { background: var(--accent); color: white; border-color: var(--accent); }
      .button.primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); box-shadow: 0 3px 10px rgba(234,108,47,0.28); transform: translateY(-1px); }
      .button.secondary { background: var(--surface); color: var(--ink-2); border-color: var(--border-strong); }
      .button.secondary:hover { background: var(--bg); box-shadow: var(--shadow-sm); transform: translateY(-1px); }

      .muted { color: var(--muted); }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 22px 24px 36px;
      }

      .footer-copy {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .footer-links { display: flex; gap: 18px; }
      .footer-links a { color: var(--muted); transition: color 150ms; }
      .footer-links a:hover { color: var(--ink); }

      /* ── Responsive ── */
      @media (max-width: 980px) {
        .sidebar { display: none; }
        .content-area { padding: 28px 24px 64px; max-width: 100%; }
        .grid.two, .grid.three, .metric-grid { grid-template-columns: 1fr; }
      }

      @media (max-width: 720px) {
        h1 { font-size: 1.8rem; }
        .surface, .card { padding: 20px; }
        .nav-links { gap: 2px; }
        .nav-link { padding: 6px 9px; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a class="brand-wrap" href="/">
          <div class="brand-mark">B</div>
          <div class="brand">BridgeAIChat</div>
          <div class="beta-badge">Beta</div>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {topNav.map((item) => (
            <a
              class={`nav-link${pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) ? ' active' : ''}`}
              href={item.href}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <div class="docs-wrapper">
      <aside class="sidebar" aria-label="Docs navigation">
        <div class="sidebar-inner">
          {sidebar.map((group) => (
            <div class="sidebar-group">
              <span class="sidebar-group-label">{group.group}</span>
              {group.links.map((link) => (
                <a class={`sidebar-link${isActive(link.href) ? ' active' : ''}`} href={link.href}>
                  {link.label}
                </a>
              ))}
            </div>
          ))}
        </div>
      </aside>

      <div class="content-area">
        {crumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="breadcrumb-sep">›</span>
            {crumbs.map((crumb, i) => (
              <>
                {crumb.href === '#' ? (
                  <span class="breadcrumb-current">{crumb.label}</span>
                ) : (
                  <a href={crumb.href}>{crumb.label}</a>
                )}
                {i < crumbs.length - 1 && <span class="breadcrumb-sep">›</span>}
              </>
            ))}
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-current">{title.replace(' — BridgeAIChat', '').replace('BridgeAIChat ', '')}</span>
          </nav>
        )}
        <slot />
      </div>
    </div>

    <footer>
      <div class="footer-copy">
        <div>BridgeAIChat beta — v0.1.0-beta.1</div>
        <div class="footer-links">
          <a href="/downloads">Install</a>
          <a href="/docs/quickstart">Quickstart</a>
          <a href="/roadmap">Roadmap</a>
        </div>
      </div>
    </footer>
  </body>
</html>
